{{> head}}
{{> header}}

<article>
    <h1>{{course.title}}</h1>
    <p class="muted">
        Level: {{course.level}} • Type: {{course.type}} {{#course.allowDropIn}}• Drop-in available{{/course.allowDropIn}}
    </p>
    <p>{{course.description}}</p>
    <p class="muted">Dates: {{course.startDate}} – {{course.endDate}}</p>

    <section>
        <h2>Book the full course</h2>
        {{#user}}
            <form action="/courses/{{course.id}}/book" method="post">
                <input type="hidden" name="userId" value="{{user.id}}">
                <button class="btn primary" type="submit">Book full course</button>
            </form>
        {{/user}}
        {{^user}}
            <a href="/login?redirect=/courses/{{course.id}}" class="btn primary">Book full course</a>
        {{/user}}
    </section>

    <section>
        <h2>Sessions</h2>
        <table class="table">
            <thead>
            <tr><th>Start</th><th>End</th><th>Capacity</th><th>Booked</th><th>Remaining</th><th></th></tr>
            </thead>
            <tbody>
            {{#sessions}}
                <tr>
                    <td>{{start}}</td>
                    <td>{{end}}</td>
                    <td>{{capacity}}</td>
                    <td>{{booked}}</td>
                    <td>{{remaining}}</td>
                    <td>
                        {{#allowDropIn}}
                            {{#user}}
                                <form action="/sessions/{{id}}/book" method="post">
                                    <input type="hidden" name="userId" value="{{user.id}}">
                                    <button class="btn" type="submit" {{#isFull}}disabled{{/isFull}}>Book this session</button>
                                </form>
                            {{/user}}
                            {{^user}}
                                <a href="/login?redirect=/sessions/{{id}}" class="btn">Book this session</a>
                            {{/user}}
                        {{/allowDropIn}}
                        {{^allowDropIn}}
                            <span class="muted">Drop-ins disabled</span>
                        {{/allowDropIn}}
                    </td>
                </tr>
            {{/sessions}}
            </tbody>
        </table>
    </section>

    <div class="actions">
        <a href="/" class="btn">← Back to Home</a>
    </div>
</article>

{{> footer}}