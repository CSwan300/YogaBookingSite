<!--views/dashboards/adminDashboard.mustache-->
{{> head}}
{{> header}}

<main>
    <article class="wrap">
        <div class="page-hero">
            <h1>Admin Dashboard</h1>
            <p>Manage courses, classes, staff, and users</p>
        </div>

        <div class="cards">
            <a href="/dashboard/courses" class="card">
                <h3>Manage Courses</h3>
                <p>Add, edit and delete courses</p>
                <div class="btn primary">Courses →</div>
            </a>

            <a href="/dashboard/classes" class="card">
                <h3>Manage Classes</h3>
                <p>View and manage class sessions</p>
                <div class="btn primary">Classes →</div>
            </a>

            <a href="/dashboard/instructors" class="card">
                <h3>Manage Instructors</h3>
                <p>Add and remove yoga teachers</p>
                <div class="btn primary">Instructors →</div>
            </a>

            <a href="/dashboard/organisers" class="card">
                <h3>Manage Organisers</h3>
                <p>Add and remove organisers</p>
                <div class="btn primary">Organisers →</div>
            </a>

            <a href="/dashboard/users" class="card">
                <h3>Manage Users</h3>
                <p>View and remove users</p>
                <div class="btn primary">Users →</div>
            </a>
        </div>

        <div class="action-row mt-8">
            <a href="/" class="btn">← Back to Home</a>
        </div>
    </article>
</main>

{{> footer}}