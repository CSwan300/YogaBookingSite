{{> head}}
{{> header}}
<main>
    <div class="wrap">

        <div class="page-header">
            <h1>Our Instructors</h1>
            <p class="muted">Meet the teachers behind the practice.</p>
        </div>

        {{#instructors}}
            {{#-first}}
            <div class="cards">
            {{/-first}}
            <div class="card">
                <span class="tag">Instructor</span>
                <h3>{{name}}</h3>
                <div class="kv">
                    <dt>Email</dt>
                    <dd>{{email}}</dd>
                </div>
            </div>
            {{#-last}}
            </div>
            {{/-last}}
        {{/instructors}}

        {{^instructors}}
            <p class="muted">No instructors found.</p>
        {{/instructors}}

    </div>
</main>

{{> footer}}