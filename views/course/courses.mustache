{{> head}}
{{> header}}

<main class="wrap">
    <header class="page-hero">
        <h1>Upcoming Courses</h1>
        <p class="help-text">Explore our current blocks and workshops.</p>
    </header>

    <div class="schedule-controls">
        <form id="filter-form" class="filter-group" method="GET" action="/courses">
            <div class="search-wrap">
                <input
                        type="text"
                        name="q"
                        class="filter-input"
                        placeholder="Search courses..."
                        aria-label="Search courses"
                        autocomplete="off"
                >
            </div>

            <div class="select-wrap">
                <select name="level" class="filter-select">
                    <option value="">All Levels</option>
                    <option value="beginner">Beginner</option>
                    <option value="intermediate">Intermediate</option>
                    <option value="advanced">Advanced</option>
                </select>
            </div>

            <div class="select-wrap">
                <select name="type" class="filter-select">
                    <option value="">All Types</option>
                    <option value="block">Block</option>
                    <option value="workshop">Workshop</option>
                </select>
            </div>

            <div class="select-wrap">
                <select name="price" class="filter-select">
                    <option value="">Any Price</option>
                    <option value="50">Under £50</option>
                    <option value="100">Under £100</option>
                    <option value="200">Under £200</option>
                    <option value="300">Under £300</option>
                </select>
            </div>

            <div class="select-wrap">
                <select name="dropin" class="filter-select">
                    <option value="">All Drop-in</option>
                    <option value="true">Drop-in OK</option>
                    <option value="false">Block Only</option>
                </select>
            </div>

            <a href="/courses" class="btn" id="filter-reset">Clear</a>
        </form>
    </div>

    <div class="cards">
        {{#courses}}
            <section class="card">
                <span class="tag">{{level}}</span>
                <h3>{{title}}</h3>

                <p class="muted">
                    {{#allowDropIn}}
                        <span class="tag tag-success">Single Lessons Available</span>
                    {{/allowDropIn}}
                    {{^allowDropIn}}
                        <span class="tag tag-info">Block Lessons Only</span>
                    {{/allowDropIn}}
                </p>

                <p>{{description}}</p>

                <div class="course-details">
                    <p class="price-full"><strong>Full Block:</strong> £{{price}}</p>

                    {{#allowDropIn}}
                        <p class="price-dropin">
                            <strong>Drop-in:</strong> £{{displayDropInPrice}} <span class="muted">/ session</span>
                        </p>
                    {{/allowDropIn}}

                    <div class="course-meta">
                        <p class="muted">Location: {{location}}</p>
                        <p class="muted">Dates: {{startDate}} – {{endDate}}</p>
                        <p class="muted">Next: {{nextSession}}</p>
                    </div>
                </div>

                <div class="card-footer">
                    <a href="/courses/{{id}}" class="btn primary">View &amp; Book</a>
                </div>
            </section>
        {{/courses}}

        {{^courses}}
            <div class="no-results">
                <p class="muted">No courses match your criteria.</p>
                <a href="/courses" class="btn">View all courses</a>
            </div>
        {{/courses}}
    </div>

    <div class="pagination-wrap">
        <nav class="pagination" aria-label="Page navigation">
            {{#pagination.hasPrev}}
                <a href="/courses?page={{pagination.prevPage}}{{pagination.queryParams}}" class="btn">← Previous</a>
            {{/pagination.hasPrev}}

            <div class="page-numbers">
                {{#pagination.pages}}
                    <a href="/courses?page={{number}}{{pagination.queryParams}}" class="btn{{#isCurrent}} active{{/isCurrent}}">{{number}}</a>
                {{/pagination.pages}}
            </div>

            {{#pagination.hasNext}}
                <a href="/courses?page={{pagination.nextPage}}{{pagination.queryParams}}" class="btn">Next →</a>
            {{/pagination.hasNext}}
        </nav>
    </div>
</main>

{{> footer}}

<script>
    (function () {
        'use strict';

        const filterForm = document.getElementById('filter-form');
        const selects    = document.querySelectorAll('.filter-select');
        const searchInput = document.querySelector('.filter-input');
        const urlParams  = new URLSearchParams(window.location.search);

        /**
         * Debounce function to prevent submitting the form on every single keypress.
         * It waits until the user stops typing for 'delay' milliseconds.
         */
        function debounce(func, delay) {
            let timeout;
            return function(...args) {
                clearTimeout(timeout);
                timeout = setTimeout(() => func.apply(this, args), delay);
            };
        }

        // 1. Restore state from URL on page load
        selects.forEach(function (select) {
            const val = urlParams.get(select.name);
            if (val !== null) select.value = val;
        });

        if (searchInput && urlParams.has('q')) {
            searchInput.value = urlParams.get('q');
            // Put cursor at the end of the text
            searchInput.focus();
            searchInput.setSelectionRange(searchInput.value.length, searchInput.value.length);
        }

        // 2. Auto-submit dropdowns when they change
        selects.forEach(function (select) {
            select.addEventListener('change', function () {
                filterForm.submit();
            });
        });

        // 3. Search as user types (with 300ms debounce)
        if (searchInput) {
            searchInput.addEventListener('input', debounce(function () {
                filterForm.submit();
            }, 300));
        }

    }());
</script>