{{> head}}
{{> header}}

<article>
    <h1>Class Schedule</h1>
    <div class="schedule-controls">

        <div class="schedule-controls-left">
            {{#user}}
                <div class="toggle-group">
                    <a href="/schedule" class="btn {{^showMyBookings}}active{{/showMyBookings}}">All Classes</a>
                    <a href="/schedule?my=1" class="btn {{#showMyBookings}}active{{/showMyBookings}}">My Bookings</a>
                </div>
            {{/user}}
            {{^user}}
                <p class="muted">
                    <a class="btn" href="/login?redirect=/schedule">Sign in to view your booked classes.</a>
                </p>
            {{/user}}
        </div>

        <div class="schedule-controls-right">
            <div class="filter-group">
                <select id="filter-week" class="filter-select">
                    <option value="">All Weeks</option>
                </select>
                <select id="filter-day" class="filter-select">
                    <option value="">All Days</option>
                    <option value="Mon">Mon</option>
                    <option value="Tue">Tue</option>
                    <option value="Wed">Wed</option>
                    <option value="Thu">Thu</option>
                    <option value="Fri">Fri</option>
                    <option value="Sat">Sat</option>
                    <option value="Sun">Sun</option>
                </select>
                <button id="filter-reset" class="btn">Clear Filters</button>
            </div>
        </div>

    </div>


    {{#weeks}}
        <section class="calendar-week" data-week="{{label}}">
            <h2 class="week-heading">{{label}}</h2>
            <div class="calendar-grid">
                {{#days}}
                    <div class="calendar-day {{#isEmpty}}empty{{/isEmpty}}" data-day="{{dayName}}">
                        <div class="day-heading">
                            <span class="day-name">{{dayName}}</span>
                            <span class="day-date">{{date}}</span>
                        </div>
                        {{#sessions}}
                            <div class="session-card {{#isBooked}}booked{{/isBooked}} {{#isFull}}full{{/isFull}}">
                                <div class="session-time">{{start}} – {{end}}</div>
                                <div class="session-title">{{courseTitle}}</div>
                                <div class="session-meta muted">{{courseLevel}} · {{duration}}</div>

                                {{#canBook}}
                                    <div class="session-dropin muted">No booking required</div>
                                {{/canBook}}

                                {{#isFull}}
                                    <div class="session-spots muted">Full</div>
                                {{/isFull}}
                                {{^isFull}}
                                    <div class="session-spots muted">{{spotsLeft}} places left</div>
                                {{/isFull}}

                                {{#isBooked}}
                                    <span class="badge booked">Booked</span>
                                {{/isBooked}}

                                <div class="session-actions">
                                    {{#isBooked}}
                                        <form method="post" action="/bookings/{{bookingId}}/cancel">
                                            <input type="hidden" name="returnTo" value="/schedule{{#showMyBookings}}?my=1{{/showMyBookings}}">
                                            <button class="btn danger" type="submit">Cancel</button>
                                        </form>
                                    {{/isBooked}}

                                    {{^isBooked}}
                                        {{#user}}
                                            <form method="post" action="/sessions/{{id}}/book">
                                                <input type="hidden" name="returnTo" value="/schedule{{#showMyBookings}}?my=1{{/showMyBookings}}">
                                                <button class="btn" type="submit" {{#isFull}}disabled{{/isFull}}>
                                                    {{#isFull}}Full{{/isFull}}{{^isFull}}Book{{/isFull}}
                                                </button>
                                            </form>
                                        {{/user}}
                                        {{^user}}
                                            <a href="/login?redirect=/schedule" class="btn">Book</a>
                                        {{/user}}
                                    {{/isBooked}}
                                </div>
                            </div>
                        {{/sessions}}
                        {{#isEmpty}}
                            <p class="no-sessions muted">No classes</p>
                        {{/isEmpty}}
                    </div>
                {{/days}}
            </div>
        </section>
    {{/weeks}}

    {{^weeks}}
        <p class="muted">No classes scheduled.</p>
    {{/weeks}}
</article>

<script>
    (function () {
        var weekSelect = document.getElementById('filter-week');
        var daySelect = document.getElementById('filter-day');
        var weekSections = document.querySelectorAll('.calendar-week');

        // Populate week filter
        weekSections.forEach(function (section) {
            var label = section.dataset.week;
            var option = document.createElement('option');
            option.value = label;
            option.textContent = label;
            weekSelect.appendChild(option);
        });

        function applyFilters() {
            var selectedWeek = weekSelect.value;
            var selectedDay = daySelect.value;

            weekSections.forEach(function (section) {
                var weekMatch = !selectedWeek || section.dataset.week === selectedWeek;

                // Show/hide entire week section
                section.style.display = weekMatch ? '' : 'none';

                if (weekMatch) {
                    // Filter days within visible weeks
                    var days = section.querySelectorAll('.calendar-day');
                    days.forEach(function (day) {
                        var dayMatch = !selectedDay || day.dataset.day === selectedDay;
                        day.style.display = dayMatch ? '' : 'none';
                    });
                }
            });
        }

        // Event listeners
        weekSelect.addEventListener('change', applyFilters);
        daySelect.addEventListener('change', applyFilters);

        document.getElementById('filter-reset').addEventListener('click', function () {
            weekSelect.value = '';
            daySelect.value = '';
            applyFilters();
        });

        // Initial filter application
        applyFilters();
    })();
</script>

{{> footer}}
