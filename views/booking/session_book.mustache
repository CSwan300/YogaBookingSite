{{> head}}
{{> header}}

<main>
    <article class="wrap booking-wrap">

        <div class="page-hero">
            <div class="course-meta-tags">
                <span class="tag">{{course.level}}</span>
                <span class="tag">{{course.type}}</span>
                <span class="tag tag--dropin">Drop-in available</span>
            </div>
            <h1>Drop-in: {{course.title}}</h1>
            <p class="help-text">{{course.description}}</p>
        </div>

        {{#errors}}
            <div class="alert error" role="alert" aria-live="assertive">
                <ul>
                    {{#list}}
                        <li>{{.}}</li>
                    {{/list}}
                </ul>
            </div>
        {{/errors}}

        <form method="post" action="/sessions/book">

            <div class="form-section">
                <h2 class="form-section__title">Your details</h2>

                <div class="field">
                    <label for="name">Full name</label>
                    <input id="name" name="name" type="text" required value="{{user.name}}">
                </div>

                <div class="field">
                    <label for="email">Email</label>
                    <input id="email" name="email" type="email" required value="{{user.email}}">
                </div>

                <div class="field">
                    <label for="notes">Notes (injuries, preferences)</label>
                    <textarea id="notes" name="notes" rows="4" placeholder="Optional">{{notes}}</textarea>
                </div>

                <div class="field checkbox">
                    <input id="consent" name="consent" type="checkbox" required>
                    <label for="consent">I agree to the studio's booking terms &amp; health disclaimer.</label>
                </div>
            </div>

            <div class="form-section">
                <h2 class="form-section__title">Choose sessions</h2>
                <p class="help-text">Select one or more sessions to attend as drop-ins.</p>

                <div class="session-options">
                    {{#sessions}}
                        {{^isPast}}
                            <div class="field checkbox-session{{#isFull}} checkbox-session--full{{/isFull}}">
                                <input
                                        id="session-{{id}}"
                                        name="sessionIds"
                                        type="checkbox"
                                        value="{{id}}"
                                        {{#isFull}}disabled{{/isFull}}
                                >
                                <label for="session-{{id}}">
                                    <span class="session-label-date">{{start}}</span>
                                    {{#isFull}}
                                        <span class="badge full">Full</span>
                                    {{/isFull}}
                                    {{^isFull}}
                                        <span class="badge available-badge">{{remaining}} place{{#pluralRemaining}}s{{/pluralRemaining}} left</span>
                                    {{/isFull}}
                                </label>
                            </div>
                        {{/isPast}}
                    {{/sessions}}

                    {{^sessions}}
                        <p class="alert alert-muted">No upcoming sessions are available for drop-in booking.</p>
                    {{/sessions}}
                </div>
            </div>

            <div class="actions">
                <button class="btn primary" type="submit" {{^sessions}}disabled{{/sessions}}>
                    Confirm Drop-in Booking
                </button>
                <a href="/courses/{{course.id}}/book" class="btn">Book full course instead</a>
                <a href="/courses/{{course.id}}" class="btn ghost">Back to course</a>
            </div>

        </form>
    </article>
</main>

{{> footer}}
