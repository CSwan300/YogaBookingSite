<!--views/misc/instructors.mustache-->
{{> head}}
{{> header}}

<main class="wrap">
    <header class="course-page-header">
        <h1>Our Instructors</h1>
        <p class="muted">Meet the teachers behind the practice.</p>
    </header>

    <div class="cards">
        {{#instructors}}
            <article class="card instructor-card">
                <div class="instructor-image">
                    <img src="{{image}}" alt="{{name}}">
                </div>

                <div class="instructor-content">
                    <span class="tag">Instructor</span>
                    <h3>{{name}}</h3>

                    {{#bio}}
                        <p class="instructor-bio">{{bio}}</p>
                    {{/bio}}

                    <div class="course-details">
                        <div class="kv">
                            <dt class="muted">Contact</dt>
                            <dd><a href="mailto:{{email}}">{{email}}</a></dd>
                        </div>
                    </div>
                </div>
            </article>
        {{/instructors}}

        {{^instructors}}
            <div class="no-results">
                <p class="muted">No instructors found at this time.</p>
            </div>
        {{/instructors}}
    </div>
</main>

{{> footer}}