<!--views/course/course.mustache-->
{{> head}}
{{> header}}

<article class="wrap">
    <div class="page-hero">
        <h1>{{course.title}}</h1>
        <p class="muted">
            Level: {{course.level}} &bull; Type: {{course.type}}{{#course.allowDropIn}} &bull; Drop-in available{{/course.allowDropIn}}
        </p>
    </div>

    <p>{{course.description}}</p>
    <p class="muted">Dates: {{course.startDate}} – {{course.endDate}}</p>
    <p class="muted">Location: {{course.location}}</p>

    <section class="booking-box">
        <h2>Book the remaining course</h2>

        {{#course.allowDropIn}}
            <p class="muted">
                There are <strong>{{course.upcomingCount}}</strong> sessions remaining at £{{course.displayDropInPrice}} each.
            </p>
            <p class="price-display">Total for remaining sessions: <strong>£{{course.dynamicTotal}}</strong></p>
        {{/course.allowDropIn}}

        {{^course.allowDropIn}}
            <p class="price-display">Full Block Price: <strong>£{{course.price}}</strong></p>
        {{/course.allowDropIn}}

        {{#user}}
            <form action="/courses/{{course.id}}/book" method="post">
                <input type="hidden" name="userId" value="{{user.id}}">
                <button class="btn primary" type="submit">
                    Book {{#course.allowDropIn}}Remaining{{/course.allowDropIn}} Course
                </button>
            </form>
        {{/user}}

        {{^user}}
            <a href="/login?redirect=/courses/{{course.id}}" class="btn primary">Login to Book</a>
        {{/user}}
    </section>

    <section class="sessions-section">
        <h2>Sessions</h2>
        <div class="table-wrap">
            <table class="table">
                <thead>
                <tr>
                    <th>Start</th>
                    <th>End</th>
                    <th>Price</th>
                    <th>Capacity</th>
                    <th>Remaining</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                {{#sessions}}
                    {{^isPast}}
                        <tr>
                            <td>{{start}}</td>
                            <td>{{end}}</td>
                            <td>
                                {{#allowDropIn}}£{{dropInPrice}}{{/allowDropIn}}
                                {{^allowDropIn}}—{{/allowDropIn}}
                            </td>
                            <td>{{capacity}}</td>
                            <td>{{remaining}}</td>
                            <td>
                                {{#allowDropIn}}
                                    {{#user}}
                                        <form action="/courses/{{courseId}}/book/session" method="get">
                                            <input type="hidden" name="sessionId" value="{{id}}">
                                            <button class="btn small" type="submit" {{#isFull}}disabled{{/isFull}}>
                                                Book Session
                                            </button>
                                        </form>
                                    {{/user}}
                                    {{^user}}
                                        <a href="/login?redirect=/sessions/{{id}}" class="btn small">Login</a>
                                    {{/user}}
                                {{/allowDropIn}}
                                {{^allowDropIn}}
                                    <span class="muted">Block Only</span>
                                {{/allowDropIn}}
                            </td>
                        </tr>
                    {{/isPast}}
                {{/sessions}}
                </tbody>
            </table>
        </div>
    </section>

    <div class="actions">
        <a href="/" class="btn">← Back to Home</a>
    </div>
</article>

{{> footer}}
