{{> head}}
{{> header}}

<div class="profile-wrap">
    <div class="profile-card">

        <div class="avatar-container">
            {{#image}}
                <img src="{{image}}" alt="{{name}}" class="avatar-img">
            {{/image}}
            {{^image}}
                <div class="avatar-fallback">{{userInitials}}</div>
            {{/image}}
        </div>

        <h1 class="user-name" style="margin-bottom: 0.25rem;">Edit Profile</h1>
        <p class="user-email">Update your account details below.</p>

        {{#errors}}
        <div class="alert error">
            <ul>
                {{#list}}
                    <li>{{msg}}</li>
                {{/list}}
            </ul>
        </div>
        {{/errors}}

        <form method="POST" action="/profile/edit" novalidate>
            <fieldset>
                <div class="field">
                    <label for="name">Name</label>
                    <input
                        type="text"
                        id="name"
                        name="name"
                        value="{{name}}"
                        autocomplete="name"
                        required
                    >
                </div>

                <div class="field">
                    <label for="email">Email</label>
                    <input
                        type="email"
                        id="email"
                        name="email"
                        value="{{email}}"
                        autocomplete="email"
                        required
                    >
                </div>
            </fieldset>

            <p class="muted" style="font-size: 0.8rem; margin-top: 1rem; text-align: left;">
                Your profile picture is generated automatically from your name
                and will update when you save.
            </p>

            <div class="actions">
                <button type="submit" class="btn-edit">Save Changes</button>
                <a href="/profile" class="btn-signout">Cancel</a>
            </div>
        </form>

    </div>
</div>

{{> footer}}
