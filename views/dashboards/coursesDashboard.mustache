{{> head}}
{{> header}}

<main>
    <article class="wrap">
        <div class="page-hero">
            <h1>Manage Courses</h1>
            {{#success}}<div class="alert success">Operation successful!</div>{{/success}}
        </div>

        <div class="card">
            <h3>Add New Course</h3>

            <form method="POST" action="/dashboard/courses" class="form-grid">
                <div class="field">
                    <label for="course-title">Title</label>
                    <input id="course-title" type="text" name="title" placeholder="e.g. 8-Week Hatha" required>
                </div>

                <div class="field">
                    <label for="course-level">Level</label>
                    <div class="select-wrap">
                        <select id="course-level" name="level">
                            <option value="beginner">Beginner</option>
                            <option value="intermediate">Intermediate</option>
                            <option value="advanced">Advanced</option>
                        </select>
                    </div>
                </div>

                <div class="field">
                    <label for="course-type">Type (Category)</label>
                    <div class="select-wrap">
                        <select id="course-type" name="type" required>
                            <option value="" disabled selected>Select type…</option>
                            <option value="weekly_block">Weekly Block</option>
                            <option value="workshop">Workshop</option>
                            <option value="retreat">Retreat</option>
                            <option value="one_off">One-off Session</option>
                        </select>
                    </div>
                </div>

                <div class="field">
                    <label for="course-price">Price (£)</label>
                    <input id="course-price" type="number" name="price" step="0.01" placeholder="0.00" required>
                </div>

                <div class="field">
                    <label for="course-start">Course Start Date</label>
                    <input id="course-start" type="date" name="startDate" required>
                </div>

                <div class="field">
                    <label for="course-end">Course End Date</label>
                    <input id="course-end" type="date" name="endDate" required>
                </div>

                <div class="field">
                    <label for="course-instructor">Instructor</label>
                    <div class="select-wrap">
                        <select id="course-instructor" name="instructorId" required>
                            <option value="" disabled selected>Select an instructor</option>
                            {{#instructors}}
                                <option value="{{id}}">{{name}}</option>
                            {{/instructors}}
                        </select>
                    </div>
                </div>

                <div class="field checkbox">
                    <input type="checkbox" id="dropin" name="allowDropIn">
                    <label for="dropin">Allow Drop-in Bookings</label>
                </div>

                <div class="actions">
                    <button type="submit" class="btn primary">Create Course</button>
                </div>
            </form>
        </div>

        <div class="table-wrap">
            <table class="table">
                <thead>
                <tr>
                    <th>Title</th>
                    <th>Level</th>
                    <th>Price</th>
                    <th>Schedule</th>
                    <th>Sessions</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {{#courses}}
                    <tr>
                        <td>
                            <strong>{{title}}</strong>
                            <br>
                            <small class="muted">{{type}}</small>
                        </td>
                        <td><span class="badge">{{level}}</span></td>
                        <td>£{{price}}</td>
                        <td>
                            <div class="kv-inline">
                                <span class="muted">Start:</span> {{startDate}}<br>
                                <span class="muted">End:</span> {{endDate}}
                            </div>
                        </td>
                        <td class="text-center">{{sessionsCount}}</td>
                        <td>
                            <div class="btn-group">
                                <a href="/dashboard/courses/{{_id}}/update" class="btn small">Edit</a>
                                <form method="POST" action="/dashboard/courses/{{_id}}/delete">
                                    <button type="submit" class="btn small danger" onclick="return confirm('Delete this course?')">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {{/courses}}
                {{^courses}}
                    <tr>
                        <td colspan="6" class="text-center muted">No courses created yet.</td>
                    </tr>
                {{/courses}}
                </tbody>
            </table>
        </div>

        <div class="actions">
            <a href="/dashboard" class="btn">← Back to Dashboard</a>
        </div>
    </article>
</main>

{{> footer}}
