<!--views/dashboards/updateCourse.mustache-->
{{> head}}
{{> header}}

<main>
    <article class="wrap">
        <div class="page-hero">
            <h1>Edit Course: {{course.title}}</h1>
            <p class="help-text">Update course details or add new sessions below.</p>
        </div>

        <!-- ── Course details ─────────────────────────────────────── -->
        <div class="card">
            <h3>Course Details</h3>
            <form method="POST" action="/dashboard/courses/{{course._id}}/update" class="form-grid">

                <div class="field">
                    <label for="edit-title">Title</label>
                    <input id="edit-title" type="text" name="title" value="{{course.title}}" required>
                </div>

                <div class="field">
                    <label for="edit-level">Level</label>
                    <div class="select-wrap">
                        <select id="edit-level" name="level">
                            <option value="beginner"     {{#course.isBeginnerLevel}}selected{{/course.isBeginnerLevel}}>Beginner</option>
                            <option value="intermediate" {{#course.isIntermediateLevel}}selected{{/course.isIntermediateLevel}}>Intermediate</option>
                            <option value="advanced"     {{#course.isAdvancedLevel}}selected{{/course.isAdvancedLevel}}>Advanced</option>
                        </select>
                    </div>
                </div>

                <div class="field">
                    <label for="edit-type">Type</label>
                    <div class="select-wrap">
                        <select id="edit-type" name="type" required>
                            <option value="WEEKLY_BLOCK"     {{#course.isWeeklyBlock}}selected{{/course.isWeeklyBlock}}>Weekly Block</option>
                            <option value="WEEKEND_WORKSHOP" {{#course.isWeekendWorkshop}}selected{{/course.isWeekendWorkshop}}>Weekend Workshop</option>
                        </select>
                    </div>
                </div>

                <div class="field">
                    <label for="edit-price">Block Price (£)</label>
                    <input id="edit-price" type="number" name="price" step="0.01" value="{{course.price}}" required>
                </div>

                <div class="field">
                    <label for="edit-start">Start Date</label>
                    <input id="edit-start" type="date" name="startDate" value="{{course.startDate}}" required>
                </div>

                <div class="field">
                    <label for="edit-end">End Date</label>
                    <input id="edit-end" type="date" name="endDate" value="{{course.endDate}}" required>
                </div>

                <div class="field">
                    <label for="edit-instructor">Instructor</label>
                    <div class="select-wrap">
                        <select id="edit-instructor" name="instructorId" required>
                            {{#instructors}}
                                <option value="{{id}}" {{#isSelected}}selected{{/isSelected}}>{{name}}</option>
                            {{/instructors}}
                        </select>
                    </div>
                </div>

                <div class="field">
                    <label for="edit-location">Location</label>
                    <input id="edit-location" type="text" name="location" value="{{course.location}}" placeholder="e.g. Studio A">
                </div>

                <div class="field">
                    <label for="edit-description">Description</label>
                    <textarea id="edit-description" name="description" rows="3">{{course.description}}</textarea>
                </div>

                <div class="field checkbox">
                    <input type="checkbox" id="edit-dropin" name="allowDropIn" {{#course.allowDropIn}}checked{{/course.allowDropIn}}>
                    <label for="edit-dropin">Allow Drop-in Bookings</label>
                </div>

                <div class="field" id="edit-dropin-price-field" style="display:{{#course.allowDropIn}}block{{/course.allowDropIn}}{{^course.allowDropIn}}none{{/course.allowDropIn}};">
                    <label for="edit-dropin-price">Drop-in Price per Session (£)</label>
                    <input id="edit-dropin-price" type="number" name="dropInPrice" step="0.01" value="{{course.dropInPrice}}">
                </div>

                <div class="actions">
                    <button type="submit" class="btn primary">Save Changes</button>
                    <a href="/dashboard/courses" class="btn">Cancel</a>
                </div>
            </form>
        </div>

        <!-- ── Existing sessions ───────────────────────────────────── -->
        <div class="card">
            <h3>Sessions</h3>
            {{#sessions}}
                <div class="table-wrap">
                    <table class="table">
                        <thead>
                        <tr>
                            <th>Start</th>
                            <th>End</th>
                            <th>Duration</th>
                            <th>Capacity</th>
                            <th>Booked</th>
                            <th>Spots Left</th>
                            <th></th>
                        </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>{{start}}</td>
                                <td>{{end}}</td>
                                <td>{{duration}}</td>
                                <td>{{capacity}}</td>
                                <td>{{booked}}</td>
                                <td>
                                    {{#isFull}}<span class="badge danger">Full</span>{{/isFull}}
                                    {{^isFull}}{{spotsLeft}}{{/isFull}}
                                </td>
                                <td>
                                    <button
                                            type="button"
                                            class="btn danger small"
                                            data-session-id="{{id}}"
                                            data-session-start="{{start}}"
                                            data-booked="{{booked}}"
                                            onclick="confirmDeleteSession(this)">
                                        Delete
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            {{/sessions}}
            {{^sessions}}
                <p class="muted">No sessions added yet.</p>
            {{/sessions}}
        </div>

        <!-- ── Add session ─────────────────────────────────────────── -->
        <div class="card">
            <h3>Add Session</h3>

            {{#course.isWeeklyBlock}}
                <p class="help-text">
                    This is a weekly block course. Entering a start time below will automatically
                    create one session per week from that date until the course end date
                    ({{course.endDate}}).
                </p>
            {{/course.isWeeklyBlock}}
            {{#course.isWeekendWorkshop}}
                <p class="help-text">
                    This is a weekend workshop. Each submission adds a single session.
                    Add each session slot individually.
                </p>
            {{/course.isWeekendWorkshop}}

            <form method="POST" action="/sessions" class="form-grid">
                <input type="hidden" name="courseId" value="{{course._id}}">
                <input type="hidden" name="isDropIn" value="false">

                <div class="field">
                    <label for="session-start">Start Date &amp; Time</label>
                    <input id="session-start" type="datetime-local" name="startDateTime" required>
                </div>

                <div class="field">
                    <label for="session-duration">Duration (minutes)</label>
                    <input id="session-duration" type="number" name="durationMins" value="60" min="15" step="15" required>
                </div>

                <div class="field">
                    <label for="session-capacity">Capacity</label>
                    <input id="session-capacity" type="number" name="capacity" value="15" min="1" required>
                </div>

                <div class="actions">
                    <button type="submit" class="btn primary">
                        {{#course.isWeeklyBlock}}Generate Weekly Sessions{{/course.isWeeklyBlock}}
                        {{#course.isWeekendWorkshop}}Add Session{{/course.isWeekendWorkshop}}
                        {{^course.isWeeklyBlock}}{{^course.isWeekendWorkshop}}Add Session{{/course.isWeekendWorkshop}}{{/course.isWeeklyBlock}}
                    </button>
                </div>
            </form>
        </div>

        <!-- ── Add drop-in session ─────────────────────────────────── -->
        {{#course.allowDropIn}}
            <div class="card">
                <h3>Add Drop-in Session</h3>
                {{#course.isWeeklyBlock}}
                    <p class="help-text">
                        Add a single drop-in slot. Unlike block sessions, this will not auto-generate weekly repeats.
                    </p>
                {{/course.isWeeklyBlock}}
                {{#course.isWeekendWorkshop}}
                    <p class="help-text">
                        Add a single drop-in slot for this workshop.
                    </p>
                {{/course.isWeekendWorkshop}}

                <form method="POST" action="/sessions" class="form-grid">
                    <input type="hidden" name="courseId" value="{{course._id}}">
                    <input type="hidden" name="isDropIn" value="true">

                    <div class="field">
                        <label for="dropin-session-start">Start Date &amp; Time</label>
                        <input id="dropin-session-start" type="datetime-local" name="startDateTime" required>
                    </div>

                    <div class="field">
                        <label for="dropin-session-duration">Duration (minutes)</label>
                        <input id="dropin-session-duration" type="number" name="durationMins" value="60" min="15" step="15" required>
                    </div>

                    <div class="field">
                        <label for="dropin-session-capacity">Capacity</label>
                        <input id="dropin-session-capacity" type="number" name="capacity" value="15" min="1" required>
                    </div>

                    <div class="actions">
                        <button type="submit" class="btn primary">Add Drop-in Session</button>
                    </div>
                </form>
            </div>
        {{/course.allowDropIn}}

        <div class="actions">
            <a href="/dashboard/courses" class="btn">← Back to Courses</a>
        </div>
    </article>
</main>

<!-- ── Delete confirmation dialog ─────────────────────────────── -->
<dialog id="delete-session-dialog">
    <div class="card">
        <h3>Delete Session</h3>
        <p id="delete-session-message"></p>
        <p id="delete-session-warning" class="text-danger" style="display:none;">
            ⚠ This session has active bookings. Deleting it will affect those users.
        </p>
        <div class="actions">
            <button type="button" class="btn" onclick="document.getElementById('delete-session-dialog').close()">Cancel</button>
            <form id="delete-session-form" method="POST">
                <button type="submit" class="btn danger">Delete</button>
            </form>
        </div>
    </div>
</dialog>

<script>
    const dropinCheckbox   = document.getElementById("edit-dropin");
    const dropinPriceField = document.getElementById("edit-dropin-price-field");

    dropinCheckbox.addEventListener("change", function () {
        dropinPriceField.style.display = this.checked ? "block" : "none";
    });

    function confirmDeleteSession(btn) {
        const sessionId    = btn.dataset.sessionId;
        const sessionStart = btn.dataset.sessionStart;
        const booked       = parseInt(btn.dataset.booked, 10);

        const dialog  = document.getElementById("delete-session-dialog");
        const message = document.getElementById("delete-session-message");
        const warning = document.getElementById("delete-session-warning");
        const form    = document.getElementById("delete-session-form");

        message.textContent   = `Are you sure you want to delete the session on ${sessionStart}?`;
        warning.style.display = booked > 0 ? "block" : "none";
        form.action           = `/sessions/${sessionId}/delete`;

        dialog.showModal();
    }
</script>

{{> footer}}
