{{> head}}
{{> header}}

<article class="wrap booking-wrap">

    <div class="page-hero">
        <h1>{{course.title}}</h1>
        <p class="muted">Level: {{course.level}} • Type: {{course.type}} {{#course.allowDropIn}}• Drop-in available{{/course.allowDropIn}}</p>
        <p>{{course.description}}</p>
        <p class="muted">Dates: {{course.startDate}} – {{course.endDate}} • Location: {{course.location}}</p>
    </div>

    {{#course.allowDropIn}}
        <div class="dropin-banner">
            <div class="dropin-banner-inner">
                <span>Only need one session?</span>
                <a href="/courses/{{course.id}}/book/session" class="btn primary">
                    Book a single drop-in →
                </a>
            </div>
        </div>
    {{/course.allowDropIn}}

    {{#course.allowDropIn}}
        <div class="alert info" role="note">
            <p>
                Want to attend just one session?
                <a href="/courses/{{course.id}}/book/session">Book a single drop-in session instead →</a>
            </p>
        </div>
    {{/course.allowDropIn}}

    {{#errors}}
        <div class="alert error" role="alert" aria-live="assertive">
            <ul>
                {{#list}}
                    <li>{{.}}</li>
                {{/list}}
            </ul>
        </div>
    {{/errors}}

    <form class="booking-form" method="post" action="/courses/{{course.id}}/book">
        <input type="hidden" name="userId" value="{{user.id}}">

        <fieldset>
            <legend>Your details</legend>
            <div class="field">
                <label for="name">Full name</label>
                <input id="name" name="name" type="text" required value="{{user.name}}">
            </div>
            <div class="field">
                <label for="email">Email</label>
                <input id="email" name="email" type="email" required value="{{user.email}}">
            </div>
            <div class="field">
                <label for="notes">Notes (injuries, preferences)</label>
                <textarea id="notes" name="notes" rows="4" placeholder="Optional">{{notes}}</textarea>
            </div>
            <div class="field checkbox">
                <input id="consent" name="consent" type="checkbox" required>
                <label for="consent">I agree to the studio's booking terms &amp; health disclaimer.</label>
            </div>
        </fieldset>

        <fieldset>
            <legend>Sessions</legend>
            <ul class="session-list">
                {{#sessions}}
                    <li class="session-item {{#isPast}}past{{/isPast}}">
                        <span class="session-date">{{start}}</span>
                        {{#isPast}}
                            <span class="badge muted-badge">Past</span>
                        {{/isPast}}
                        {{^isPast}}
                            <span class="badge available-badge">{{remaining}} place{{^isSinglePlace}}s{{/isSinglePlace}} left</span>
                        {{/isPast}}
                    </li>
                {{/sessions}}
            </ul>
        </fieldset>

        <fieldset>
            <legend>Booking summary</legend>
            <p>This booking reserves a seat across <strong>{{sessionsCount}}</strong> upcoming sessions:</p>
            <ul class="session-list">
                {{#sessions}}
                    {{^isPast}}
                        <li class="session-item">
                            <span class="session-date">{{start}}</span>
                            <span class="badge available-badge">{{remaining}} places left</span>
                        </li>
                    {{/isPast}}
                {{/sessions}}
            </ul>
        </fieldset>

        <div class="actions">
            <button class="btn primary" type="submit">Confirm Course Booking</button>
            <a href="/courses/{{course.id}}" class="btn">Back</a>
        </div>
    </form>
</article>

{{> footer}}
