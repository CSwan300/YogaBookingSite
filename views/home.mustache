{{> head}}
{{> header}}

<h1>Upcoming Courses</h1>

<div class="cards">
    {{#courses}}
        <article class="card">
            <h2>{{title}}</h2>
            <p class="muted">
                Level: {{level}} • Type: {{type}} {{#allowDropIn}}• Drop-in OK{{/allowDropIn}}
            </p>
            <p>{{description}}</p>
            <p class="muted">Dates: {{startDate}} – {{endDate}}</p>
            <p class="muted">Next session: {{nextSession}} • Sessions: {{sessionsCount}}</p>
            <a href="/courses/{{id}}" class="btn primary">View &amp; Book</a>
        </article>
    {{/courses}}

    {{^courses}}
        <p class="muted">No courses available yet.</p>
    {{/courses}}
</div>

{{> footer}}