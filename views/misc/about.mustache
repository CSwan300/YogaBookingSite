<!--views/misc/about.mustache-->
{{> head}}
{{> header}}

<article class="content-page">
    <h1>About {{studio.name}}</h1>
    <p class="muted">{{studio.tagline}}</p>

    <p>{{studio.description}}</p>

    {{#studio.mission}}
        <h2>Our Mission</h2>
        <p>{{studio.mission}}</p>
    {{/studio.mission}}

    {{#team}}
        <h2>Meet the Team</h2>
        <div class="instructor-cta">
            <p class="muted">Our classes are led by experienced, passionate instructors dedicated to your practice.</p>
            <a href="/instructors" class="btn primary">View all instructors →</a>
        </div>
    {{/team}}

    {{#contact}}
        <h2>Get in Touch</h2>
        <ul class="muted">
            {{#address}}<li>{{.}}</li>{{/address}}
            {{#phone}}<li><a href="tel:{{.}}">{{.}}</a></li>{{/phone}}
            {{#email}}<li><a href="mailto:{{.}}">{{.}}</a></li>{{/email}}
        </ul>
    {{/contact}}

    {{#social}}
        <h2>Follow Us</h2>
        <ul class="muted">
            {{#instagram}}<li><a href="{{.}}">Instagram</a></li>{{/instagram}}
            {{#facebook}}<li><a href="{{.}}">Facebook</a></li>{{/facebook}}
            {{#twitter}}<li><a href="{{.}}">Twitter / X</a></li>{{/twitter}}
        </ul>
    {{/social}}

    <div class="actions">
        <a class="btn primary" href="/courses">Browse Classes</a>
    </div>
</article>

{{> footer}}