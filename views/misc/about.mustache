{{> head}}
{{> header}}

<article>
    <h1>About {{studio.name}}</h1>
    <p class="muted">{{studio.tagline}}</p>

    <p>{{studio.description}}</p>

    {{#studio.mission}}
        <h2>Our Mission</h2>
        <p>{{studio.mission}}</p>
    {{/studio.mission}}

    {{#team}}
        <h2>Meet the Team</h2>
        <a href="/instructors">View all instructors</a>
    {{/team}}
    {{#contact}}
        <h2>Get in Touch</h2>
        <ul class="muted">
            {{#address}}<li>{{address}}</li>{{/address}}
            {{#phone}}<li><a href="tel:{{phone}}">{{phone}}</a></li>{{/phone}}
            {{#email}}<li><a href="mailto:{{email}}">{{email}}</a></li>{{/email}}
        </ul>
    {{/contact}}

    {{#social}}
        <h2>Follow Us</h2>
        <ul class="muted">
            {{#instagram}}<li><a href="{{instagram}}">Instagram</a></li>{{/instagram}}
            {{#facebook}}<li><a href="{{facebook}}">Facebook</a></li>{{/facebook}}
            {{#twitter}}<li><a href="{{twitter}}">Twitter / X</a></li>{{/twitter}}
        </ul>
    {{/social}}

    <div class="actions">
        <a class="btn primary" href="/courses">Browse Classes</a>
    </div>
</article>

{{> footer}}