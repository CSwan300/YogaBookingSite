{{> head}}
{{> header}}

<article class="wrap">
    <h1>{{course.title}}</h1>
    <p class="muted">
        Level: {{course.level}} • Type: {{course.type}} {{#course.allowDropIn}}• Drop-in available{{/course.allowDropIn}}
    </p>
    <p>{{course.description}}</p>
    <p class="muted">Dates: {{course.startDate}} – {{course.endDate}}</p>

    <section class="booking-box">
        <h2>Book the full course</h2>
        {{! --- SHOW FULL PRICE --- }}
        <p class="price-display">Total Price: <strong>£{{course.price}}</strong></p>

        {{#user}}
            <form action="/courses/{{course.id}}/book" method="post">
                <input type="hidden" name="userId" value="{{user.id}}">
                <button class="btn primary" type="submit">Book full course</button>
            </form>
        {{/user}}
        {{^user}}
            <a href="/login?redirect=/courses/{{course.id}}" class="btn primary">Login to Book</a>
        {{/user}}
    </section>

    <section>
        <h2>Sessions</h2>
        <table class="table">
            <thead>
            {{! --- ADDED PRICE COLUMN --- }}
            <tr><th>Start</th><th>End</th><th>Price</th><th>Capacity</th><th>Remaining</th><th></th></tr>
            </thead>
            <tbody>
            {{#sessions}}
                <tr>
                    <td>{{start}}</td>
                    <td>{{end}}</td>
                    {{! --- SHOW DROP-IN PRICE IF ALLOWED --- }}
                    <td>
                        {{#allowDropIn}}£{{dropInPrice}}{{/allowDropIn}}
                        {{^allowDropIn}}—{{/allowDropIn}}
                    </td>
                    <td>{{capacity}}</td>
                    <td>{{remaining}}</td>
                    <td>
                        {{#allowDropIn}}
                            {{#user}}
                                <form action="/courses/{{courseId}}/book/session" method="get">
                                    <input type="hidden" name="sessionId" value="{{id}}">
                                    <button class="btn" type="submit" {{#isFull}}disabled{{/isFull}}>
                                        Book Session
                                    </button>
                                </form>
                            {{/user}}
                            {{^user}}
                                <a href="/login?redirect=/sessions/{{id}}" class="btn">Login</a>
                            {{/user}}
                        {{/allowDropIn}}
                        {{^allowDropIn}}
                            <span class="muted">Block Only</span>
                        {{/allowDropIn}}
                    </td>
                </tr>
            {{/sessions}}
            </tbody>
        </table>
    </section>

    <div class="actions">
        <a href="/" class="btn">← Back to Home</a>
    </div>
</article>

{{> footer}}