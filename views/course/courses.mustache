{{> head}}
{{> header}}

<main class="wrap">
    <header style="margin-top: var(--space-2xl); margin-bottom: var(--space-xl);">
        <h1>Upcoming Courses</h1>
        <p class="muted">Explore our current blocks and workshops.</p>
    </header>

    <div class="cards">
        {{#courses}}
            <section class="card">
                <span class="tag">{{level}}</span>
                <h3>{{title}}</h3>

                <p class="muted">
                    Type: {{type}} {{#allowDropIn}}• Drop-in OK{{/allowDropIn}}
                </p>

                <p>{{description}}</p>

                <div class="course-details">
                    <p><strong>Price:</strong> £{{price}}</p>
                    <p class="muted" style="font-size: 0.85rem;">Dates: {{startDate}} – {{endDate}}</p>
                    <p class="muted" style="font-size: 0.85rem;">Next session: {{nextSession}}</p>
                </div>

                <div class="card-footer">
                    <a href="/courses/{{id}}" class="btn primary">View &amp; Book</a>
                </div>
            </section>
        {{/courses}}

        {{^courses}}
            <div style="grid-column: 1 / -1; text-align: center; padding: var(--space-2xl);">
                <p class="muted">No courses available at the moment.</p>
            </div>
        {{/courses}}
    </div>
</main>

{{> footer}}